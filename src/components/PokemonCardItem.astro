---
interface Card {
  id: string;
  name: string;
  set: string | null;
  number: string | null;
  notes: string | null;
  image: string | null;
  description: string | null;
  tags: string[];
  isJumbo: boolean;
  variant: string | null;
  language: string | null;
  rarity: string | null;
}

interface Props {
  card: Card;
}

const { card } = Astro.props;

const hasImage = Boolean(card.image);
const cardLabel = [card.name, card.set, card.number].filter(Boolean).join(' — ');
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-card transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover focus-within:ring-2 focus-within:ring-zinc-400 dark:bg-zinc-800 dark:shadow-none dark:hover:shadow-lg"
>
  <a href={`/cards/${card.id}`} class="flex flex-col flex-1" aria-label={cardLabel}>
    <!-- Card image area -->
    <div class="relative aspect-[2.5/3.5] overflow-hidden bg-zinc-100 dark:bg-zinc-700">
      {hasImage ? (
        <img
          src={card.image}
          alt={`Carta Pokémon: ${card.name}${card.set ? ` — ${card.set}` : ''}${card.number ? ` #${card.number}` : ''}`}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div
          class="flex h-full w-full flex-col items-center justify-center gap-2 text-zinc-400 dark:text-zinc-500"
          role="img"
          aria-label={`Imagen no disponible para ${card.name}`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1"
            class="h-12 w-12 opacity-30"
          >
            <rect x="3" y="5" width="18" height="14" rx="2" />
            <circle cx="12" cy="12" r="3" />
            <path d="M3 12h6m6 0h6" />
          </svg>
          <span class="text-xs font-medium opacity-50">Sin imagen</span>
        </div>
      )}

      <!-- Jumbo badge overlay -->
      {card.isJumbo && (
        <span
          class="absolute left-2 top-2 rounded-full bg-amber-400 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-amber-900 shadow"
        >
          Jumbo
        </span>
      )}

      <!-- Variant badge overlay -->
      {card.variant && !card.isJumbo && (
        <span
          class="absolute left-2 top-2 rounded-full bg-indigo-100 px-2 py-0.5 text-[10px] font-semibold text-indigo-700 shadow dark:bg-indigo-900 dark:text-indigo-300"
        >
          {card.variant}
        </span>
      )}
    </div>

    <!-- Card metadata -->
    <div class="flex flex-1 flex-col gap-1.5 p-4">
      <h2 class="font-semibold leading-tight text-zinc-900 group-hover:text-zinc-600 transition-colors line-clamp-2 dark:text-zinc-50 dark:group-hover:text-zinc-300">
        {card.name}
      </h2>

      {card.set && (
        <span class="inline-block rounded-md bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-600 w-fit dark:bg-zinc-700 dark:text-zinc-300">
          {card.set}
        </span>
      )}

      {card.number && (
        <p class="text-xs text-zinc-400 dark:text-zinc-500">
          #{card.number}
        </p>
      )}

      {card.notes && (
        <p class="mt-auto pt-2 text-xs italic text-zinc-500 line-clamp-2 dark:text-zinc-400">
          {card.notes}
        </p>
      )}

      <!-- Tags -->
      {card.tags.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-1 pt-2" aria-label="Etiquetas">
          {card.tags.map((tag) => (
            <span class="rounded bg-zinc-100 px-1.5 py-0.5 text-[10px] font-medium text-zinc-500 dark:bg-zinc-700 dark:text-zinc-400">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
