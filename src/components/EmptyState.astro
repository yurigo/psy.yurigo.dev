---
interface Props {
  message?: string;
}

const { message = 'No hay cartas en la colección por el momento.' } = Astro.props;
---

<div class="flex flex-col items-center justify-center gap-6 py-24 text-center">
  <div
    class="flex h-20 w-20 items-center justify-center rounded-full bg-zinc-100"
    aria-hidden="true"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      class="h-10 w-10 text-zinc-400"
    >
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="M3 10h18" />
    </svg>
  </div>
  <div>
    <p class="text-lg font-medium text-zinc-700">{message}</p>
    <p class="mt-1 text-sm text-zinc-500">
      Añade cartas a <code class="rounded bg-zinc-100 px-1 py-0.5 text-xs">src/data/cards.json</code> para empezar.
    </p>
  </div>
</div>
