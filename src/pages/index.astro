---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import CardGallery from '../components/CardGallery.astro';
import { getCards, getSets } from '../lib/cards.js';

const allCards = await getCards();
const sets = await getSets();

// Simple search & filter — driven by URL query params at runtime via JS
// The initial render shows everything; client-side script handles filtering
---

<BaseLayout>
  <Header slot="header" totalCards={allCards.length} />

  <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Filters -->
    <div class="mb-8 flex flex-col gap-3 sm:flex-row sm:items-center">
      <!-- Search -->
      <div class="relative flex-1 max-w-sm">
        <label for="search-input" class="sr-only">Buscar carta</label>
        <span class="pointer-events-none absolute inset-y-0 left-3 flex items-center text-zinc-400" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
          </svg>
        </span>
        <input
          id="search-input"
          type="search"
          placeholder="Buscar por nombre…"
          class="w-full rounded-xl border border-zinc-200 bg-white py-2.5 pl-9 pr-4 text-sm text-zinc-900 placeholder-zinc-400 shadow-sm outline-none transition focus:border-zinc-400 focus:ring-2 focus:ring-zinc-200 dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-50 dark:placeholder-zinc-500 dark:focus:border-zinc-500 dark:focus:ring-zinc-700"
          autocomplete="off"
        />
      </div>

      <!-- Set filter -->
      <div class="relative">
        <label for="set-filter" class="sr-only">Filtrar por colección</label>
        <select
          id="set-filter"
          class="appearance-none rounded-xl border border-zinc-200 bg-white py-2.5 pl-4 pr-9 text-sm text-zinc-700 shadow-sm outline-none transition focus:border-zinc-400 focus:ring-2 focus:ring-zinc-200 cursor-pointer dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-300 dark:focus:border-zinc-500 dark:focus:ring-zinc-700"
        >
          <option value="">Todas las colecciones</option>
          {sets.map((set) => (
            <option value={set}>{set}</option>
          ))}
        </select>
        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-zinc-400" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </span>
      </div>

      <!-- Sort -->
      <div class="relative">
        <label for="sort-select" class="sr-only">Ordenar</label>
        <select
          id="sort-select"
          class="appearance-none rounded-xl border border-zinc-200 bg-white py-2.5 pl-4 pr-9 text-sm text-zinc-700 shadow-sm outline-none transition focus:border-zinc-400 focus:ring-2 focus:ring-zinc-200 cursor-pointer dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-300 dark:focus:border-zinc-500 dark:focus:ring-zinc-700"
        >
          <option value="default">Sin ordenar</option>
          <option value="name-asc">Nombre (A→Z)</option>
          <option value="name-desc">Nombre (Z→A)</option>
          <option value="set-asc">Colección (A→Z)</option>
        </select>
        <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-zinc-400" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </span>
      </div>
    </div>

    <!-- Card count after filtering (updated by JS) -->
    <p id="card-count" class="mb-4 text-sm text-zinc-500 dark:text-zinc-400" aria-live="polite">
      Mostrando {allCards.length} {allCards.length === 1 ? 'carta' : 'cartas'}
    </p>

    <!-- Gallery -->
    <div id="gallery-wrapper">
      <CardGallery cards={allCards} />
    </div>

    <!-- No results message (hidden by default) -->
    <p
      id="no-results"
      class="hidden py-16 text-center text-zinc-500 dark:text-zinc-400"
      role="status"
    >
      No se encontraron cartas con ese criterio de búsqueda.
    </p>
  </div>
</BaseLayout>

<script>
  // Inline data so client JS can filter without extra fetch
  const rawCards = document.querySelectorAll('#gallery-wrapper article');

  const searchInput = document.getElementById('search-input');
  const setFilter = document.getElementById('set-filter');
  const sortSelect = document.getElementById('sort-select');
  const cardCount = document.getElementById('card-count');
  const noResults = document.getElementById('no-results');
  const galleryList = document.querySelector('#gallery-wrapper ul');

  // Build an array of { el, name, set } for sorting/filtering
  function getCardItems() {
    return Array.from(document.querySelectorAll('#gallery-wrapper li')).map((li) => {
      const article = li.querySelector('article');
      const heading = article?.querySelector('h2');
      const setSpan = article?.querySelector('span.rounded-md');
      return {
        li,
        name: heading?.textContent?.trim().toLowerCase() ?? '',
        set: setSpan?.textContent?.trim() ?? '',
      };
    });
  }

  function applyFilters() {
    const query = searchInput?.value?.trim().toLowerCase() ?? '';
    const selectedSet = setFilter?.value ?? '';
    const sortValue = sortSelect?.value ?? 'default';

    let items = getCardItems();

    // Filter by name
    if (query) {
      items = items.filter((item) => item.name.includes(query));
    }

    // Filter by set
    if (selectedSet) {
      items = items.filter((item) => item.set === selectedSet);
    }

    // Sort
    if (sortValue === 'name-asc') {
      items.sort((a, b) => a.name.localeCompare(b.name));
    } else if (sortValue === 'name-desc') {
      items.sort((a, b) => b.name.localeCompare(a.name));
    } else if (sortValue === 'set-asc') {
      items.sort((a, b) => a.set.localeCompare(b.set));
    }

    // Hide all, show matching
    const allLis = document.querySelectorAll('#gallery-wrapper li');
    allLis.forEach((li) => li.classList.add('hidden'));

    items.forEach(({ li }) => li.classList.remove('hidden'));

    // Update count
    const count = items.length;
    if (cardCount) {
      cardCount.textContent = `Mostrando ${count} ${count === 1 ? 'carta' : 'cartas'}`;
    }

    // Show/hide no-results
    if (noResults) {
      noResults.classList.toggle('hidden', count > 0);
    }
    if (galleryList) {
      galleryList.classList.toggle('hidden', count === 0);
    }
  }

  searchInput?.addEventListener('input', applyFilters);
  setFilter?.addEventListener('change', applyFilters);
  sortSelect?.addEventListener('change', applyFilters);
</script>
