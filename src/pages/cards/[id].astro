---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { getCards, getCardById } from '../../lib/cards.js';

export async function getStaticPaths() {
  const cards = await getCards();
  return cards.map((card) => ({
    params: { id: card.id },
  }));
}

const { id } = Astro.params;
const card = await getCardById(id);

if (!card) {
  return Astro.redirect('/404');
}

const hasImage = Boolean(card.image);
const pageTitle = [card.name, card.set, card.number ? `#${card.number}` : null]
  .filter(Boolean)
  .join(' — ');
---

<BaseLayout title={pageTitle}>
  <Header slot="header" />

  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- Back link -->
    <a
      href="/"
      class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-zinc-500 transition-colors hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-400 rounded"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Volver a la galería
    </a>

    <div class="grid gap-10 md:grid-cols-2">
      <!-- Image -->
      <div class="flex items-start justify-center">
        <div class="relative w-full max-w-xs overflow-hidden rounded-2xl bg-zinc-100 shadow-card-hover aspect-[2.5/3.5]">
          {hasImage ? (
            <img
              src={card.image}
              alt={`Carta Pokémon: ${card.name}${card.set ? ` — ${card.set}` : ''}${card.number ? ` #${card.number}` : ''}`}
              class="h-full w-full object-cover"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div
              class="flex h-full w-full flex-col items-center justify-center gap-3 text-zinc-400"
              role="img"
              aria-label={`Imagen no disponible para ${card.name}`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1"
                class="h-16 w-16 opacity-25"
              >
                <rect x="3" y="5" width="18" height="14" rx="2" />
                <circle cx="12" cy="12" r="3" />
                <path d="M3 12h6m6 0h6" />
              </svg>
              <span class="text-sm font-medium opacity-40">Imagen no disponible</span>
              <span class="text-xs opacity-30">Añádela en public/images/cards/</span>
            </div>
          )}

          {card.isJumbo && (
            <span class="absolute left-3 top-3 rounded-full bg-amber-400 px-2.5 py-1 text-xs font-bold uppercase tracking-wider text-amber-900 shadow">
              Jumbo
            </span>
          )}
        </div>
      </div>

      <!-- Metadata -->
      <div class="flex flex-col gap-5">
        <div>
          <h1 class="text-2xl font-bold text-zinc-900 sm:text-3xl">{card.name}</h1>
          {card.variant && (
            <p class="mt-1 text-base text-zinc-500">{card.variant}</p>
          )}
        </div>

        <dl class="flex flex-col gap-3 text-sm">
          {card.set && (
            <div class="flex items-start gap-3">
              <dt class="w-28 shrink-0 font-medium text-zinc-500">Colección</dt>
              <dd>
                <span class="inline-block rounded-md bg-zinc-100 px-2 py-0.5 font-medium text-zinc-700">
                  {card.set}
                </span>
              </dd>
            </div>
          )}

          {card.number && (
            <div class="flex items-start gap-3">
              <dt class="w-28 shrink-0 font-medium text-zinc-500">Número</dt>
              <dd class="text-zinc-800">#{card.number}</dd>
            </div>
          )}

          {card.rarity && (
            <div class="flex items-start gap-3">
              <dt class="w-28 shrink-0 font-medium text-zinc-500">Rareza</dt>
              <dd class="text-zinc-800">{card.rarity}</dd>
            </div>
          )}

          {card.language && (
            <div class="flex items-start gap-3">
              <dt class="w-28 shrink-0 font-medium text-zinc-500">Idioma</dt>
              <dd class="text-zinc-800">{card.language}</dd>
            </div>
          )}

          {card.notes && (
            <div class="flex items-start gap-3">
              <dt class="w-28 shrink-0 font-medium text-zinc-500">Notas</dt>
              <dd class="italic text-zinc-600">{card.notes}</dd>
            </div>
          )}
        </dl>

        {card.tags.length > 0 && (
          <div>
            <p class="mb-2 text-xs font-medium uppercase tracking-wider text-zinc-400">Etiquetas</p>
            <div class="flex flex-wrap gap-1.5" aria-label="Etiquetas">
              {card.tags.map((tag) => (
                <span class="rounded-full bg-zinc-100 px-3 py-1 text-xs font-medium text-zinc-600">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}

        {card.description && (
          <div class="rounded-xl border border-zinc-200 bg-zinc-50 p-4">
            <p class="text-xs font-medium uppercase tracking-wider text-zinc-400 mb-2">Descripción</p>
            <p class="text-sm leading-relaxed text-zinc-700">{card.description}</p>
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
